{
  "name": "vue-gtag",
  "description": "Global Site Tag (gtag.js) plugin for Vue",
  "version": "3.0.0-beta.1",
  "author": {
    "name": "Matteo Gabriele",
    "email": "m.gabriele.dev@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MatteoGabriele/vue-gtag"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest",
    "test:cov": "vitest run --coverage"
  },
  "keywords": [
    "google",
    "google analytics",
    "tracking",
    "google tracking",
    "vue-analytics",
    "vue-gtag",
    "gtag",
    "gtag.js",
    "global site tag",
    "vue",
    "vuejs"
  ],
  "main": "./dist/vue-gtag.mjs",
  "module": "./dist/vue-gtag.mjs",
  "unpkg": "./dist/vue-gtag.mjs",
  "jsdelivr": "./dist/vue-gtag.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bugs": {
    "url": "https://github.com/MatteoGabriele/vue-gtag/issues"
  },
  "homepage": "https://github.com/MatteoGabriele/vue-gtag#readme",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "flush-promises": "^1.0.2",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "mockdate": "^3.0.5",
    "prettier": "^3.3.3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.14.0",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.5",
    "vue": "^3.0.0",
    "vue-router": "^4.0.0"
  },
  "dependencies": {
    "@types/gtag.js": "^0.0.20"
  }
